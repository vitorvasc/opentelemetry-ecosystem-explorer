      "gauge": {
        "aggregation_temporality": "delta",
        "monotonic": false,
        "value_type": "double"
      },
      "stability": "development",
      "unit": "{insert}/s"
    },
    "mongodb.repl_queries_per_sec": {
      "description": "The number of replicated queries executed per second.",
      "enabled": false,
      "gauge": {
        "aggregation_temporality": "delta",
        "monotonic": false,
        "value_type": "double"
      },
      "stability": "development",
