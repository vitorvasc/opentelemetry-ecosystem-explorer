      "enum": [
        "active",
        "deleted"
      ],
      "name_override": "state",
      "type": "string"
    },
    "get_result": {
      "description": "Result of get operation",
      "enum": [
        "hit",
        "miss"
      ],
      "name_override": "result",
      "type": "string"
    },
    "health_status": {
      "description": "The health status of the cluster.",
      "enum": [
        "green",
        "red",
        "yellow"
      ],
      "name_override": "status",
      "type": "string"
    },
    "index_aggregation_type": {
      "description": "Type of shard aggregation for index statistics",
      "enum": [
        "primary_shards",
        "total"
      ],
